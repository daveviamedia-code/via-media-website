---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/hosting/', label: 'Hosting' },
  { href: '/portfolio/', label: 'Portfolio' },
  { href: '/support/', label: 'Support' },
  { href: '/contact/', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-via-cream/90 backdrop-blur-md border-b border-gray-200/50">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-24">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <img 
          src="/logo.png" 
          alt="Via Media" 
          class="h-10 w-auto transition-transform duration-300 group-hover:scale-105"
          width="120"
          height="40"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 text-sm font-medium text-via-gray rounded-lg
                   transition-all duration-200
                   hover:text-via-orange hover:bg-via-orange/10
                   focus:outline-none focus:ring-2 focus:ring-via-orange/50
                   {[ '/', '/hosting/', '/portfolio/', '/support/', '/contact/' ].includes(currentPath) && link.href === currentPath ? 'text-via-orange bg-via-orange/10' : ''}"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:block">
        <a href="/contact/" class="btn-primary !px-6 !py-2.5 !text-sm">
          Get Started
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn"
        class="md:hidden p-2 text-via-gray hover:text-via-orange transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="md:hidden hidden bg-white border-t border-gray-100 shadow-lg"
  >
    <nav class="px-6 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-4 py-3 text-base font-medium text-via-gray rounded-lg
                 transition-all duration-200
                 hover:text-via-orange hover:bg-via-orange/10
                 focus:outline-none focus:ring-2 focus:ring-via-orange/50
                 {[ '/', '/hosting/', '/portfolio/', '/support/', '/contact/' ].includes(currentPath) && link.href === currentPath ? 'text-via-orange bg-via-orange/10' : ''}"
        >
          {link.label}
        </a>
      ))}
      <a href="/contact/" class="btn-primary !mt-2 !w-full !justify-center">
        Get Started
      </a>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.classList.toggle('hidden');
  });
</script>
