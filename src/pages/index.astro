---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Web Design',
    description: 'Op maat gemaakte, responsieve websites die uw publiek boeien en conversies stimuleren.',
    icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
  },
  {
    title: 'Web Hosting',
    description: 'Snelle, veilige en betrouwbare hostingoplossingen met 99,9% uptime garantie.',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2m-2-4h.01M17 16h.01'
  },
  {
    title: 'Support',
    description: '24/7 technische ondersteuning om uw digitale aanwezigheid soepel te laten verlopen.',
    icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z'
  }
];

const stats = [
  { value: '500+', label: 'Projecten Voltooid' },
  { value: '98%', label: 'Klanttevredenheid' },
  { value: '24/7', label: 'Support Beschikbaar' },
  { value: '10+', label: 'Jaren Ervaring' }
];
---

<Layout
  title="Home"
  description="Via Media - Digitale oplossingen voor moderne bedrijven. Op maat gemaakt webdesign, betrouwbare hosting en uitzonderlijke ondersteuning."
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/4 -right-32 w-96 h-96 bg-via-orange/10 rounded-full blur-3xl animate-float" />
      <div class="absolute bottom-1/4 -left-32 w-96 h-96 bg-via-red/10 rounded-full blur-3xl animate-float delay-1000" />
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-br from-via-orange/5 to-via-red/5 rounded-full blur-3xl" />
    </div>

    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-24 py-20">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Hero Content -->
        <div class="animate-slide-up">
          <span class="section-label">Welkom bij Via Media</span>
          <h1 class="text-display-md md:text-display-lg font-bold mb-6 text-balance">
            Digitale Excellentie,
            <span class="gradient-text"> Opgeleverd</span>
          </h1>
          <p class="text-lg md:text-xl text-via-gray-light mb-10 leading-relaxed max-w-lg">
            Wij maken prachtige websites, bieden betrouwbare hosting, en leveren
            uitzonderlijke ondersteuning om uw bedrijf te laten gedijen in het digitale tijdperk.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact/" class="btn-primary !text-center">
              Start Uw Project
            </a>
            <a href="/portfolio/" class="btn-secondary !text-center">
              Bekijk Ons Werk
            </a>
          </div>
        </div>

        <!-- Hero Visual -->
        <div class="relative hidden lg:block animate-fade-in delay-200">
          <div class="relative z-10">
            <!-- Abstract geometric composition -->
            <div class="relative w-full aspect-square max-w-md mx-auto">
              <div class="absolute inset-0 bg-gradient-to-br from-via-orange to-via-red rounded-3xl opacity-20 rotate-6" />
              <div class="absolute inset-0 bg-via-gray-dark rounded-3xl -rotate-6" />
              <div class="absolute inset-0 flex items-center justify-center">
                <img 
                  src="/logo.png" 
                  alt="Via Media" 
                  class="w-48 h-48 object-contain brightness-0 invert"
                />
              </div>
              <!-- Floating elements -->
              <div class="absolute -top-4 -right-4 w-20 h-20 bg-via-orange rounded-2xl flex items-center justify-center shadow-lg animate-float">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div class="absolute -bottom-4 -left-4 w-16 h-16 bg-white rounded-2xl flex items-center justify-center shadow-lg animate-float delay-300">
                <svg class="w-8 h-8 text-via-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-via-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-via-gray-dark py-16">
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-24">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat, index) => (
          <div class="text-center animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
            <div class="text-4xl md:text-5xl font-bold text-via-orange mb-2">{stat.value}</div>
            <div class="text-gray-400 text-sm">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-white">
    <div class="max-w-content mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">Wat We Doen</span>
        <h2 class="text-display-md font-bold mb-6">
          Oplossingen voor Elke Behoefte
        </h2>
        <p class="text-via-gray-light max-w-2xl mx-auto">
          Van concept tot implementatie en verder, wij bieden uitgebreide
          digitale diensten om uw bedrijf te helpen slagen online.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {services.map((service, index) => (
          <div class="card group cursor-pointer">
            <div class="w-14 h-14 bg-via-orange/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-via-orange transition-colors duration-300">
              <svg class="w-7 h-7 text-via-orange group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-via-gray-light leading-relaxed">{service.description}</p>
            <a href={index === 0 ? '/portfolio/' : index === 1 ? '/hosting/' : '/support/'} class="inline-flex items-center gap-2 mt-6 text-via-orange font-medium group-hover:gap-3 transition-all duration-300">
              Meer informatie
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section-padding">
    <div class="max-w-content mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="relative">
          <div class="relative z-10 grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="bg-via-orange rounded-2xl p-6 h-48 flex items-end">
                <span class="text-white text-3xl font-bold">10+</span>
              </div>
              <div class="bg-via-gray-dark rounded-2xl p-6 h-64" />
            </div>
            <div class="space-y-4 pt-12">
              <div class="bg-via-red rounded-2xl p-6 h-64" />
              <div class="bg-gray-200 rounded-2xl p-6 h-48" />
            </div>
          </div>
          <div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-br from-via-orange/20 to-via-red/20 rounded-3xl blur-2xl" />
        </div>

        <div>
          <span class="section-label">Over Ons</span>
          <h2 class="text-display-md font-bold mb-6">
            Digitale Ervaringen Sinds 2014
          </h2>
          <p class="text-via-gray-light leading-relaxed mb-6">
            Via Media is een full-service digitaal agentschap toegewijd aan het helpen van
            bedrijven om online te slagen. Wij combineren creatief ontwerp, technische
            expertise en strategisch denken om resultaten te leveren die ertoe doen.
          </p>
          <p class="text-via-gray-light leading-relaxed mb-8">
            Ons team van ervaren ontwerpers, ontwikkelaars en supportspecialisten
            werkt samen om ervoor te zorgen dat uw digitale aanwezigheid niet alleen functioneel is,
            maar uitzonderlijk.
          </p>
          <ul class="space-y-4 mb-8">
            {[
              'Bekroond designteam',
              'Geavanceerde technologiestack',
              'Toegewijde supportspecialisten',
              'Bewezen staat van dienst'
            ].map((item) => (
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-via-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-via-gray-dark">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn-primary">
            Werk Met Ons
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-gradient-to-br from-via-orange to-via-red relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-64 h-64 bg-white rounded-full blur-3xl" />
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl" />
    </div>
    
    <div class="max-w-content mx-auto px-6 md:px-12 lg:px-24 relative z-10 text-center">
      <h2 class="text-display-md font-bold text-white mb-6">
        Klaar om Uw Digitale Aanwezigheid te Transformeren?
      </h2>
      <p class="text-white/90 text-lg max-w-2xl mx-auto mb-10">
        Laten we uw project bespreken en onderzoeken hoe Via Media u kan helpen
        uw doelen te bereiken.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-white text-via-orange font-medium rounded-lg hover:bg-gray-100 transition-all duration-300 shadow-lg">
          Neem Contact Op
        </a>
        <a href="/hosting/" class="inline-flex items-center justify-center px-8 py-4 bg-transparent text-white font-medium rounded-lg border-2 border-white hover:bg-white/10 transition-all duration-300">
          Bekijk Hosting Pakketten
        </a>
      </div>
    </div>
  </section>
</Layout>
