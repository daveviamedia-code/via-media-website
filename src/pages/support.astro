---
import Layout from '../layouts/Layout.astro';

const helpCategories = [
  {
    title: 'Getting Started',
    description: 'New to Via Media? Start here',
    icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
    articles: ['Setting up your account', 'Understanding your dashboard', 'First steps guide']
  },
  {
    title: 'Hosting',
    description: 'Manage your hosting services',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v6a2 2 0 002 2h14a2 2 0 002-2v-6a2 2 0 00-2-2m-2-4h.01M17 16h.01',
    articles: ['Domain setup', 'SSL certificates', 'FTP access', 'Database management']
  },
  {
    title: 'Web Design',
    description: 'Design services and resources',
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    articles: ['Design process overview', 'Revision policy', 'File formats guide']
  },
  {
    title: 'Billing',
    description: 'Payments and subscriptions',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    articles: ['Payment methods', 'Invoice history', 'Subscription plans', 'Refund policy']
  },
  {
    title: 'Technical',
    description: 'Technical documentation',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    articles: ['API documentation', 'DNS configuration', 'Email setup', 'Security best practices']
  },
  {
    title: 'Account',
    description: 'Manage your account settings',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    articles: ['Profile settings', 'Password reset', 'Two-factor authentication', 'Account deletion']
  }
];

const faqs = [
  {
    question: 'How do I reset my password?',
    answer: 'Go to the login page and click "Forgot Password". Enter your email address and we\'ll send you a link to reset your password. If you don\'t receive the email within a few minutes, check your spam folder.'
  },
  {
    question: 'How can I upgrade my hosting plan?',
    answer: 'Log into your account dashboard, navigate to "Hosting" > "Manage Plans", and select the plan you want to upgrade to. The change will take effect immediately, and you\'ll only be charged the prorated difference.'
  },
  {
    question: 'Do you offer phone support?',
    answer: 'Yes, phone support is available for Professional and Enterprise plan customers. You can find your dedicated support number in your account dashboard under "Support" > "Contact Us".'
  },
  {
    question: 'What is your uptime guarantee?',
    answer: 'We offer different uptime guarantees based on your plan: Starter (99.5%), Professional (99.9%), and Enterprise (99.99%). If we fail to meet our guarantee, you\'re eligible for service credits.'
  },
  {
    question: 'Can I transfer my domain to Via Media?',
    answer: 'Yes, we offer free domain transfer with any annual hosting plan. The transfer process typically takes 5-7 days. Contact our support team to initiate the transfer.'
  },
  {
    question: 'How do I set up SSL for my website?',
    answer: 'All our hosting plans include free SSL certificates. For new domains, SSL is automatically provisioned within 24 hours. For existing domains, you can enable SSL from your hosting control panel with one click.'
  }
];

const contactOptions = [
  {
    title: 'Live Chat',
    description: 'Chat with our support team',
    availability: 'Available 24/7',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
    cta: 'Start Chat',
    color: 'via-orange'
  },
  {
    title: 'Email Support',
    description: 'Get help via email',
    availability: 'Response within 24 hours',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    cta: 'Send Email',
    color: 'via-gray'
  },
  {
    title: 'Submit Ticket',
    description: 'For technical issues',
    availability: 'Priority response',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    cta: 'Create Ticket',
    color: 'via-red'
  }
];
---

<Layout 
  title="Support"
  description="Get help with your Via Media services. Browse our knowledge base, FAQs, or contact our 24/7 support team."
>
  <!-- Hero Section -->
  <section class="section-padding pt-32 bg-via-gray-dark">
    <div class="max-w-content mx-auto text-center">
      <span class="section-label">Support Center</span>
      <h1 class="text-display-md md:text-display-lg font-bold text-white mb-6">
        How Can We Help?
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
        Find answers, guides, and support resources to help you succeed.
      </p>

      <!-- Search Bar -->
      <div class="max-w-2xl mx-auto">
        <div class="relative">
          <input 
            type="text" 
            id="search-input"
            placeholder="Search for articles, guides, and more..." 
            class="w-full px-6 py-5 pl-14 bg-white rounded-2xl text-via-gray-dark placeholder-via-gray-light/60 focus:outline-none focus:ring-2 focus:ring-via-orange text-lg"
          />
          <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-6 h-6 text-via-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Help Categories -->
  <section class="section-padding bg-white -mt-20 relative z-10">
    <div class="max-w-content mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {helpCategories.map((category) => (
          <div class="card group cursor-pointer">
            <div class="w-12 h-12 bg-via-orange/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-via-orange transition-colors duration-300">
              <svg class="w-6 h-6 text-via-orange group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={category.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold mb-2">{category.title}</h3>
            <p class="text-via-gray-light text-sm mb-4">{category.description}</p>
            <ul class="space-y-2">
              {category.articles.map((article) => (
                <li>
                  <a href="#" class="text-sm text-via-gray hover:text-via-orange transition-colors flex items-center gap-2">
                    <svg class="w-4 h-4 text-via-orange/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                    {article}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="section-padding">
    <div class="max-w-content mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">Get in Touch</span>
        <h2 class="text-display-md font-bold mb-6">
          Contact Support
        </h2>
        <p class="text-via-gray-light max-w-2xl mx-auto">
          Can't find what you're looking for? Our support team is here to help.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {contactOptions.map((option) => (
          <div class="card text-center group">
            <div class={`w-16 h-16 bg-${option.color}/10 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-${option.color} transition-colors duration-300`}>
              <svg class={`w-8 h-8 text-${option.color} group-hover:text-white transition-colors duration-300`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={option.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">{option.title}</h3>
            <p class="text-via-gray-light text-sm mb-2">{option.description}</p>
            <p class="text-via-gray text-xs mb-6">{option.availability}</p>
            <a href="/contact/" class={`btn-primary !w-full !justify-center ${option.color !== 'via-orange' ? '!bg-via-gray-dark hover:!bg-via-gray-dark/90' : ''}`}>
              {option.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="section-padding bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">FAQ</span>
        <h2 class="text-display-md font-bold mb-6">
          Frequently Asked Questions
        </h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details class="group bg-via-cream rounded-2xl border border-gray-200 open:border-via-orange/50 transition-colors duration-300">
            <summary class="flex items-center justify-between cursor-pointer p-6 list-none">
              <span class="font-semibold text-via-gray-dark pr-8">{faq.question}</span>
              <svg class="w-5 h-5 text-via-gray flex-shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-via-gray-light leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Status Section -->
  <section class="section-padding bg-via-gray-dark">
    <div class="max-w-content mx-auto">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white mb-4">System Status</h2>
          <p class="text-gray-400 mb-6">
            All systems operational. Check our status page for real-time updates 
            on service performance and any ongoing incidents.
          </p>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-3 h-3 bg-green-500 rounded-full animate-pulse" />
            <span class="text-green-400 text-sm font-medium">All Systems Operational</span>
          </div>
          <a href="#" class="text-via-orange font-medium hover:underline inline-flex items-center gap-2">
            View Status Page
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="bg-white/5 rounded-2xl p-6 backdrop-blur-sm">
          <div class="space-y-4">
            {[
              { service: 'Web Hosting', status: 'operational' },
              { service: 'DNS Services', status: 'operational' },
              { service: 'Email Services', status: 'operational' },
              { service: 'API', status: 'operational' }
            ].map((item) => (
              <div class="flex items-center justify-between py-3 border-b border-white/10 last:border-0">
                <span class="text-white">{item.service}</span>
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 bg-green-500 rounded-full" />
                  <span class="text-green-400 text-sm">Operational</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Search functionality
  const searchInput = document.getElementById('search-input');
  
  searchInput?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    console.log('Search query:', query);
    // In production, this would filter articles or trigger a search API
  });
</script>
