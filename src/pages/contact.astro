---
import Layout from '../layouts/Layout.astro';

const contactInfo = [
  {
    title: 'Visit Us',
    details: ['123 Digital Avenue', 'Suite 456', 'San Francisco, CA 94102'],
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z'
  },
  {
    title: 'Email Us',
    details: ['hello@viamedia.com', 'support@viamedia.com'],
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
  },
  {
    title: 'Call Us',
    details: ['+1 (555) 123-4567', 'Mon-Fri 9am-6pm PST'],
    icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
  }
];

const departments = [
  { value: '', label: 'Select a department' },
  { value: 'sales', label: 'Sales - New projects & quotes' },
  { value: 'support', label: 'Technical Support' },
  { value: 'billing', label: 'Billing & Payments' },
  { value: 'design', label: 'Design Services' },
  { value: 'general', label: 'General Inquiry' }
];
---

<Layout 
  title="Contact"
  description="Get in touch with Via Media. Contact us for new projects, support, billing questions, or general inquiries."
>
  <!-- Hero Section -->
  <section class="section-padding pt-32">
    <div class="max-w-content mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">Get in Touch</span>
        <h1 class="text-display-md md:text-display-lg font-bold mb-6">
          Let's Start a <span class="gradient-text">Conversation</span>
        </h1>
        <p class="text-xl text-via-gray-light max-w-2xl mx-auto">
          Have a project in mind? We'd love to hear from you. 
          Send us a message and we'll respond as soon as possible.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Form & Info -->
  <section class="section-padding pt-0 bg-white">
    <div class="max-w-content mx-auto">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <form id="contact-form" class="space-y-6" action="#" method="POST">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="firstName" class="block text-sm font-medium text-via-gray-dark mb-2">
                  First Name *
                </label>
                <input 
                  type="text" 
                  id="firstName" 
                  name="firstName" 
                  required
                  class="input-field"
                  placeholder="John"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-via-gray-dark mb-2">
                  Last Name *
                </label>
                <input 
                  type="text" 
                  id="lastName" 
                  name="lastName" 
                  required
                  class="input-field"
                  placeholder="Doe"
                />
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-via-gray-dark mb-2">
                  Email Address *
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required
                  class="input-field"
                  placeholder="john@example.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-via-gray-dark mb-2">
                  Phone Number
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  class="input-field"
                  placeholder="+1 (555) 000-0000"
                />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-via-gray-dark mb-2">
                Company Name
              </label>
              <input 
                type="text" 
                id="company" 
                name="company" 
                class="input-field"
                placeholder="Your Company"
              />
            </div>

            <div>
              <label for="department" class="block text-sm font-medium text-via-gray-dark mb-2">
                Department *
              </label>
              <select 
                id="department" 
                name="department" 
                required
                class="input-field"
              >
                {departments.map((dept) => (
                  <option value={dept.value} disabled={dept.value === ''}>
                    {dept.label}
                  </option>
                ))}
              </select>
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-via-gray-dark mb-2">
                Subject *
              </label>
              <input 
                type="text" 
                id="subject" 
                name="subject" 
                required
                class="input-field"
                placeholder="How can we help?"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-via-gray-dark mb-2">
                Message *
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="6" 
                required
                class="input-field resize-none"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input 
                type="checkbox" 
                id="privacy" 
                name="privacy" 
                required
                class="mt-1 w-4 h-4 text-via-orange border-gray-300 rounded focus:ring-via-orange"
              />
              <label for="privacy" class="text-sm text-via-gray-light">
                I agree to the <a href="#" class="text-via-orange hover:underline">Privacy Policy</a> 
                and consent to having this website store my submitted information so they can respond 
                to my inquiry. *
              </label>
            </div>

            <button type="submit" class="btn-primary !w-full !justify-center">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          {contactInfo.map((info) => (
            <div>
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 bg-via-orange/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-via-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={info.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-via-gray-dark mb-2">{info.title}</h3>
                  {info.details.map((detail) => (
                    <p class="text-via-gray-light text-sm">{detail}</p>
                  ))}
                </div>
              </div>
            </div>
          ))}

          <!-- Map Placeholder -->
          <div class="bg-gray-200 rounded-2xl h-64 flex items-center justify-center">
            <div class="text-center text-via-gray">
              <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              <p class="text-sm">Map View</p>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="card bg-via-cream border-0">
            <h3 class="font-semibold text-via-gray-dark mb-4">Business Hours</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-via-gray">Monday - Friday</span>
                <span class="text-via-gray-dark font-medium">9:00 AM - 6:00 PM</span>
              </div>
              <div class="flex justify-between">
                <span class="text-via-gray">Saturday</span>
                <span class="text-via-gray-dark font-medium">10:00 AM - 4:00 PM</span>
              </div>
              <div class="flex justify-between">
                <span class="text-via-gray">Sunday</span>
                <span class="text-via-orange">Closed</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="section-padding">
    <div class="max-w-content mx-auto">
      <div class="text-center mb-16">
        <span class="section-label">Our Team</span>
        <h2 class="text-display-md font-bold mb-6">
          Meet the Experts
        </h2>
        <p class="text-via-gray-light max-w-2xl mx-auto">
          Real people, real expertise. Get to know the team behind Via Media.
        </p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        {[
          { name: 'Alex Rivera', role: 'CEO & Founder', initial: 'AR' },
          { name: 'Jordan Kim', role: 'Creative Director', initial: 'JK' },
          { name: 'Sam Patel', role: 'Lead Developer', initial: 'SP' },
          { name: 'Casey Chen', role: 'Support Manager', initial: 'CC' }
        ].map((member) => (
          <div class="text-center group">
            <div class="w-32 h-32 mx-auto mb-6 bg-gradient-to-br from-via-orange to-via-red rounded-full flex items-center justify-center text-white text-3xl font-bold group-hover:scale-105 transition-transform duration-300">
              {member.initial}
            </div>
            <h3 class="font-semibold text-via-gray-dark">{member.name}</h3>
            <p class="text-via-gray-light text-sm">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-via-gray-dark">
    <div class="max-w-content mx-auto text-center">
      <h2 class="text-display-md font-bold text-white mb-6">
        Prefer Email?
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-10">
        Send us an email at 
        <a href="mailto:hello@viamedia.com" class="text-via-orange hover:underline">hello@viamedia.com</a> 
        and we'll get back to you within 24 hours.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Form handling
  const form = document.getElementById('contact-form');
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // In production, this would submit to a backend or API
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    console.log('Form submitted:', data);
    
    // Show success message (in production)
    alert('Thank you for your message! We will get back to you soon.');
    form.reset();
  });
</script>
